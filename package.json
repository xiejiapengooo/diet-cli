{
  "name": "@xiejiapeng/diet-cli",
  "description": "daily diet record",
  "version": "0.2.0",
  "author": "JP",
  "license": "MIT",
  "homepage": "https://github.com/xiejiapengooo/diet-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiejiapengooo/diet-cli.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "bin": {
    "diet": "bin/run.js"
  },
  "scripts": {
    "postpack": "shx rm -f oclif.manifest.json",
    "prepack": "oclif manifest && oclif readme",
    "build": "shx rm -rf dist && tsc -b",
    "version": "oclif readme && git add README.md"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-help": "^6",
    "@oclif/plugin-plugins": "^5",
    "better-sqlite3": "^12.8.0",
    "dayjs": "^1.11.20",
    "prettier": "^3.8.1"
  },
  "devDependencies": {
    "@oclif/prettier-config": "^0.2.1",
    "@oclif/test": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/chai": "^5",
    "@types/node": "^25",
    "chai": "^6",
    "oclif": "^4",
    "shx": "^0.4.0",
    "ts-node": "^10",
    "typescript": "^5"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "./bin",
    "./dist",
    "./oclif.manifest.json"
  ],
  "keywords": [
    "diet",
    "cli"
  ],
  "type": "module",
  "oclif": {
    "bin": "diet",
    "dirname": "diet",
    "commands": "./dist/commands",
    "plugins": [
      "@oclif/plugin-help",
      "@oclif/plugin-plugins"
    ]
  },
  "types": "dist/index.d.ts"
}
